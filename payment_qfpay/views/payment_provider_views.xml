<?xml version='1.0' encoding='utf-8' ?>
<odoo>

    <record id="payment_provider_form" model="ir.ui.view">
        <field name="name">QFPay Provider Form</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <group name="provider_credentials" position='inside'>
                <group invisible="code != 'qfpay'">
                    <field name="qfpay_appcode"
                           string="QFPay AppCode"
                           required="code == 'qfpay' and state != 'disabled'"/>
                    <field name="qfpay_secret_key"
                           string="QFPay Secret Key"
                           required="code == 'qfpay' and state != 'disabled'"/>
                    <field name="qfpay_sign_type"
                           string="Sign Type"
                           required="code == 'qfpay' and state != 'disabled'"/>
                    <field name="qfpay_paysource"
                           string="Paysource"
                           required="code == 'qfpay' and state != 'disabled'"/>
                    <field name="qfpay_store_id"
                           string="QFPay Store ID"
                           required="code == 'qfpay' and state != 'disabled'"/>
                </group>
            </group>
        </field>
    </record>

</odoo>
