<odoo>

    <record id="payment_method_qfpay" model="payment.method">
        <field name="name">QFPay</field>
        <field name="code">qfpay</field>
        <field name="sequence">1000</field>
        <field name="active">True</field>
        <field name="image" type="base64" file="payment_qfpay/static/description/icon.png"/>
        <field name="support_tokenization">False</field>
        <field name="support_express_checkout">False</field>
        <field name="support_refund">partial</field>
    </record>
    
    <record id="payment_provider_qfpay" model="payment.provider">
        <field name="name">QFPay</field>
        <field name="code">qfpay</field>
        <field name="is_published">True</field>
        <field name="support_refund">partial</field>
        <field name="redirect_form_view_id" ref="redirect_form"/>
        <field name="payment_method_ids"
               eval="[Command.set([
                         ref('payment_qfpay.payment_method_qfpay'),
                     ])]"
        />
    </record>
</odoo>
